<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Cold-start window matches the coral splash so there is no background flash.
         The Android 12+ system splash shows the default app icon. -->
    <style name="Theme.HaveIt" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/brand_coral</item>
        <item name="android:statusBarColor">@color/brand_coral</item>
    </style>
</resources>
